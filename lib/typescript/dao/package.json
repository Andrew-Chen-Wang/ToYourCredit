{
  "name": "@lib/dao",
  "version": "1.0.0",
  "private": true,
  "description": "Common database access modules for reusability and clean testing",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": {
      "compiled": "./build/index.js",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./*": {
      "compiled": "./build/*.js",
      "import": "./src/*.ts",
      "require": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsc --noCheck && tsc-alias -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@template-nextjs/db": "workspace:*",
    "kysely": "catalog:",
    "uuid": "catalog:"
  },
  "devDependencies": {
    "tsc-alias": "catalog:",
    "typescript": "catalog:"
  }
}
