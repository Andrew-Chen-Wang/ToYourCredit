# Keep the Docker build context small. Builds run from the repo root:
#   docker build -f apps/<app>/Dockerfile .
node_modules
**/node_modules
.git
.next
**/.next
dist
**/dist
.turbo
**/.turbo
apps/website
apps/frontends
# pnpm install --frozen-lockfile validates every workspace importer's manifest,
# so keep the excluded apps' package.json files in the build context.
!apps/website/package.json
!apps/frontends/*/package.json
tofu
.env*
letsencrypt
*.log
.DS_Store
Dockerfile
**/Dockerfile
docker-compose*.yml
docker-compose*.yaml
.github
