{
  "name": "@template-nextjs/db",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": {
      "compiled": "./build/index.js",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./*": {
      "compiled": "./build/*.js",
      "import": "./src/*.ts",
      "require": "./src/*.ts"
    }
  },
  "scripts": {
    "db-codegen": "kysely-codegen --config-file ./.config/.kysely-codegenrc.cjs",
    "build": "tsc --noCheck && tsc-alias -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "kysely": "catalog:",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "kysely-codegen": "^0.20.0",
    "tsc-alias": "catalog:",
    "typescript": "catalog:"
  },
  "config": {
    "codegenoverrides": {}
  }
}
